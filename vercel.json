{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/the-gate",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/axis",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "Vary", "value": "*" }
      ]
    },
    {
      "source": "/thin-place",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
